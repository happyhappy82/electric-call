---
/**
 * 하단 고정 견적 요청 바
 * 성함 + 연락처 + 실시간 견적문의 버튼만
 * 버튼 클릭 → Tally 팝업 오픈
 */
interface Props {
  tallyId?: string;
}
const { tallyId = 'KYDpLg' } = Astro.props;
---

<div class="sticky-bar">
  <div class="sticky-inner">
    <p class="sticky-title">👇 간편 견적 요청하기</p>
    <div class="sticky-form">
      <input type="text" class="sticky-input" id="stickyName" placeholder="성함" />
      <input type="tel" class="sticky-input" id="stickyPhone" placeholder="연락처" />
      <button class="sticky-btn" id="stickySubmit" data-tally-id={tallyId}>
        실시간 견적문의
      </button>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  var btn = document.getElementById('stickySubmit');
  var tallyId = btn.getAttribute('data-tally-id');

  btn.addEventListener('click', function() {
    var name = document.getElementById('stickyName').value;
    var phone = document.getElementById('stickyPhone').value;

    if (!name || !phone) {
      alert('성함과 연락처를 입력해주세요.');
      return;
    }

    // Tally 팝업 오픈
    if (typeof Tally !== 'undefined') {
      Tally.openPopup(tallyId, {
        width: 500,
        hiddenFields: {
          name: name,
          phone: phone
        }
      });
    } else {
      // fallback: Tally 페이지로 이동
      window.open('https://tally.so/r/' + tallyId, '_blank');
    }
  });
})();
</script>

<!-- Tally 스크립트 로드 -->
<script is:inline>
  var d=document,w="https://tally.so/widgets/embed.js";
  if(d.querySelector('script[src="'+w+'"]')==null){var s=d.createElement("script");s.src=w;d.body.appendChild(s)}
</script>

<style>
  .sticky-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 9999;
    background: #1e2a3a;
    border-top: 2px solid #3182f6;
    padding: 16px 24px;
  }
  .sticky-inner {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
    margin-left: 30%;
  }
  .sticky-title {
    color: #fff;
    font-size: 0.9375rem;
    font-weight: 700;
    margin-bottom: 12px;
  }
  .sticky-form {
    display: flex;
    gap: 8px;
    align-items: center;
    justify-content: center;
  }
  .sticky-input {
    padding: 10px 14px;
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 8px;
    background: rgba(255,255,255,0.95);
    font-size: 0.875rem;
    font-family: inherit;
    color: #191f28;
    width: 140px;
  }
  .sticky-input:focus {
    outline: none;
    border-color: #3182f6;
    box-shadow: 0 0 0 2px rgba(49,130,246,0.2);
  }
  .sticky-btn {
    flex-shrink: 0;
    padding: 12px 28px;
    background: #3182f6;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 0.9375rem;
    font-weight: 700;
    font-family: inherit;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s;
  }
  .sticky-btn:hover {
    background: #1b64da;
  }

  @media (max-width: 768px) {
    .sticky-bar { padding: 12px 16px; }
    .sticky-form { flex-wrap: wrap; }
    .sticky-input {
      width: auto;
      flex: 1 1 calc(50% - 4px);
    }
    .sticky-btn {
      width: 100%;
      padding: 14px;
      margin-top: 4px;
    }
  }

  :global(body) {
    padding-bottom: 100px;
  }
  @media (max-width: 768px) {
    :global(body) {
      padding-bottom: 150px;
    }
  }
</style>
