---
/**
 * 소셜 프루프 팝업 — "김*수님이 방금 상담 신청했습니다"
 * 하단 왼쪽에 토스트처럼 나타났다 사라짐
 */
---

<div id="social-proof" class="sp-toast" style="display:none;">
  <div class="sp-inner">
    <div class="sp-icon">✅</div>
    <div class="sp-text">
      <p class="sp-name" id="sp-name"></p>
      <p class="sp-detail" id="sp-detail"></p>
    </div>
    <button class="sp-close" id="sp-close">&times;</button>
  </div>
</div>

<script is:inline>
(function() {
  var names = [
    '김*수', '이*영', '박*호', '최*진', '정*미',
    '강*혁', '윤*서', '임*준', '한*아', '오*석',
    '서*원', '조*현', '신*희', '황*민', '류*은'
  ];
  var regions = [
    '서울 강남구', '서울 마포구', '경기 수원시', '경기 성남시',
    '인천 남동구', '서울 송파구', '경기 고양시', '서울 영등포구',
    '경기 용인시', '서울 관악구', '경기 화성시', '인천 서구',
    '서울 노원구', '경기 부천시', '서울 강서구'
  ];
  var services = [
    '누전 수리', '합선 수리', '분전반 교체', '콘센트 증설',
    '전기배선 공사', '조명 설치', '전기 증설', '긴급 출장 수리'
  ];
  var times = ['방금', '1분 전', '3분 전', '5분 전', '8분 전', '12분 전'];

  var el = document.getElementById('social-proof');
  var nameEl = document.getElementById('sp-name');
  var detailEl = document.getElementById('sp-detail');
  var closeBtn = document.getElementById('sp-close');
  var dismissed = false;

  function pick(arr) { return arr[Math.floor(Math.random() * arr.length)]; }

  function show() {
    if (dismissed) return;
    var name = pick(names);
    var region = pick(regions);
    var service = pick(services);
    var time = pick(times);

    nameEl.textContent = name + '님이 상담 신청했습니다';
    detailEl.textContent = region + ' · ' + service + ' · ' + time;

    el.style.display = 'block';
    el.classList.remove('sp-hide');
    el.classList.add('sp-show');

    setTimeout(function() {
      el.classList.remove('sp-show');
      el.classList.add('sp-hide');
      setTimeout(function() { el.style.display = 'none'; }, 400);
    }, 4000);
  }

  closeBtn.addEventListener('click', function() {
    dismissed = true;
    el.style.display = 'none';
  });

  // 첫 팝업: 5초 후, 이후 15~25초 간격
  setTimeout(function() {
    show();
    setInterval(show, 15000 + Math.random() * 10000);
  }, 5000);
})();
</script>

<style>
  .sp-toast {
    position: fixed;
    bottom: 24px;
    left: 24px;
    z-index: 9999;
    max-width: 340px;
    pointer-events: auto;
  }
  .sp-inner {
    background: #fff;
    border: 1px solid #e5e8eb;
    border-radius: 12px;
    padding: 16px 20px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.12);
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .sp-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
  }
  .sp-text { flex: 1; }
  .sp-name {
    font-size: 0.875rem !important;
    font-weight: 600 !important;
    color: #191f28 !important;
    margin: 0 !important;
  }
  .sp-detail {
    font-size: 0.75rem !important;
    color: #8b95a1 !important;
    margin: 4px 0 0 !important;
  }
  .sp-close {
    background: none;
    border: none;
    font-size: 1.25rem;
    color: #8b95a1;
    cursor: pointer;
    padding: 0;
    line-height: 1;
    flex-shrink: 0;
  }

  .sp-show {
    animation: sp-slide-in 0.4s ease-out;
  }
  .sp-hide {
    animation: sp-slide-out 0.4s ease-in;
  }

  @keyframes sp-slide-in {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes sp-slide-out {
    from { opacity: 1; transform: translateY(0); }
    to { opacity: 0; transform: translateY(20px); }
  }

  @media (max-width: 480px) {
    .sp-toast {
      left: 12px;
      right: 12px;
      bottom: 12px;
      max-width: none;
    }
  }
</style>
